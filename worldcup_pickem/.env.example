# Copy this file to `.env` and fill in your key, OR set API_FOOTBALL_KEY
# as an environment secret (recommended when running in Claude Code on the web).
#
# Get your key from https://dashboard.api-football.com/  (or RapidAPI).
API_FOOTBALL_KEY=your_key_here

# Optional: override the API host.
# - Direct API-Football:  v3.football.api-sports.io   (default)
# - RapidAPI:             api-football-v1.p.rapidapi.com
# API_FOOTBALL_HOST=v3.football.api-sports.io
